{
  "name": "hello-pear-bare",
  "version": "0.1.0",
  "description": "Pear Runtime CLI boilerplate using Bare with OTA updater support.",
  "private": true,
  "bin": "bin.js",
  "upgrade": "pear://okug655xhy7g43cb1qyqhcdkgy7gtj9dowipogxx77mmirue4doo",
  "scripts": {
    "format": "prettier . --write",
    "test": "brittle-bare test/index.js",
    "lint": "prettier . --check && lunte",
    "start": "bare bin.js --no-updates",
    "make:darwin-arm64": "bare-build --name hello-pear-bare --standalone --host darwin-arm64 --out ./out/darwin-arm64 bin.js",
    "make:darwin-x64": "bare-build --name hello-pear-bare --standalone --host darwin-x64 --out ./out/darwin-x64 bin.js",
    "make:linux-arm64": "bare-build --name hello-pear-bare --standalone --host linux-arm64 --out ./out/linux-arm64 bin.js",
    "make:linux-x64": "bare-build --name hello-pear-bare --standalone --host linux-x64 --out ./out/linux-x64 bin.js",
    "make:win32-x64": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Build-Win32X64.ps1",
    "make:win32-x64:msix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Build-Win32X64.ps1 -Msix"
  },
  "dependencies": {
    "bare-os": "^3.9.0",
    "bare-path": "^3.0.0",
    "bare-storage": "^1.1.0",
    "corestore": "^7.9.2",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.1",
    "pear-runtime": "^1.1.1"
  },
  "devDependencies": {
    "bare-build": "^0.5.3",
    "brittle": "^3.19.0",
    "lunte": "^1.2.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/holepunchto/hello-pear-bare.git"
  },
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hello-pear-bare/issues"
  }
}
